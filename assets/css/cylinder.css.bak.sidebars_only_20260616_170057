:root {
  --bg: #060308;
  --bg2: #120714;
  --panel: #1a0b20;
  --panel2: #281033;
  --primary: #ff7a18;
  --primary2: #ff9f1c;
  --face: #00face;
  --purple: #7a35ff;
  --yellow: #ffd447;
  --text: #fff8ef;
  --muted: #d8c6b5;
  --line: rgba(255, 122, 24, 0.45);
  --shadow: rgba(0, 0, 0, 0.62);
}

* {
  box-sizing: border-box;
}

html {
  background: var(--bg);
  color: var(--text);
}

body.cylinder-body {
  min-height: 100vh;
  margin: 0;
  overflow: auto;
  color: var(--text);
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
  background:
    radial-gradient(circle at 12% 10%, rgba(255, 122, 24, 0.30), transparent 28rem),
    radial-gradient(circle at 88% 12%, rgba(0, 250, 206, 0.17), transparent 24rem),
    radial-gradient(circle at 70% 90%, rgba(122, 53, 255, 0.22), transparent 28rem),
    linear-gradient(135deg, #060308 0%, #120714 56%, #1f0b10 100%);
}

body.cylinder-ready {
  overflow: hidden;
}

a {
  color: var(--face);
  text-decoration: none;
}

a:hover,
a:focus {
  color: var(--yellow);
  text-decoration: underline;
}

.cylinder-header {
  position: fixed;
  inset: 0 0 auto 0;
  z-index: 80;
  height: 72px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.8rem clamp(1rem, 4vw, 3rem);
  background: rgba(6, 3, 8, 0.86);
  border-bottom: 1px solid rgba(255, 122, 24, 0.32);
  backdrop-filter: blur(16px);
}

.cylinder-brand {
  font-weight: 1000;
  letter-spacing: 0.08em;
  color: var(--primary);
  text-transform: uppercase;
}

.cylinder-brand span {
  color: var(--face);
}

.cylinder-header nav {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
  justify-content: flex-end;
  font-size: 0.92rem;
}

.cylinder-header nav a {
  color: var(--text);
  border: 1px solid rgba(255, 122, 24, 0.25);
  border-radius: 999px;
  padding: 0.42rem 0.72rem;
  background: rgba(255, 122, 24, 0.08);
}

.cylinder-header nav a:hover,
.cylinder-header nav a:focus {
  color: #180812;
  background: var(--primary);
  text-decoration: none;
}

.cylinder-shell {
  min-height: 100vh;
  padding-top: 82px;
  padding-bottom: 76px;
}

.cylinder-page-title {
  position: relative;
  z-index: 10;
  width: min(1040px, 92vw);
  margin: 0 auto 0.4rem;
  text-align: center;
}

.cylinder-page-title .kicker {
  margin: 0;
}

.kicker {
  color: var(--face);
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 0.82rem;
  font-weight: 900;
}

.cylinder-page-title h1 {
  margin: 0.15rem 0 0.2rem;
  color: var(--primary);
  font-size: clamp(2.2rem, 6vw, 5.4rem);
  line-height: 0.9;
  letter-spacing: -0.06em;
  text-shadow: 0 0 28px rgba(255, 122, 24, 0.25);
}

.cylinder-page-title p {
  margin: 0.35rem auto;
  max-width: 780px;
  color: var(--muted);
}

.cylinder-stage {
  position: relative;
  width: 100vw;
  height: calc(100vh - 236px);
  min-height: 470px;
  overflow: hidden;
  perspective: 1800px;
  perspective-origin: 50% 50%;
}

.cylinder-track {
  position: relative;
  width: 100%;
  height: 100%;
  transform-style: preserve-3d;
  transition: transform 720ms cubic-bezier(0.22, 1.04, 0.56, 1.05);
}

.cylinder-panel {
  width: min(860px, 86vw);
  margin: 1.2rem auto;
  padding: clamp(1.15rem, 3vw, 2.2rem);
  border-radius: 1.25rem;
  background:
    linear-gradient(135deg, rgba(54, 20, 29, 0.97), rgba(22, 8, 28, 0.97)),
    radial-gradient(circle at 78% 20%, rgba(0, 250, 206, 0.12), transparent 16rem);
  border: 1px solid var(--line);
  box-shadow:
    0 22px 70px var(--shadow),
    inset 0 0 42px rgba(255, 122, 24, 0.08);
}

.cylinder-ready .cylinder-panel {
  position: absolute;
  top: 50%;
  left: 50%;
  height: min(68vh, 720px);
  max-height: 720px;
  margin: 0;
  opacity: 0.18;
  pointer-events: none;
  overflow: hidden;
  transform-style: preserve-3d;
  backface-visibility: hidden;
  transform-origin: center center;
  transition:
    opacity 520ms ease,
    filter 520ms ease,
    box-shadow 520ms ease;
  filter: blur(0.8px) saturate(0.72) brightness(0.82);
}

.cylinder-ready .cylinder-panel.is-active {
  opacity: 1;
  pointer-events: auto;
  overflow-y: auto;
  filter: none;
  z-index: 20;
  box-shadow:
    0 24px 90px rgba(0, 0, 0, 0.74),
    0 0 44px rgba(255, 122, 24, 0.16),
    inset 0 0 44px rgba(0, 250, 206, 0.05);
}

.cylinder-panel::-webkit-scrollbar {
  width: 14px;
  background: #100714;
  border-radius: 12px;
}

.cylinder-panel::-webkit-scrollbar-thumb {
  background: linear-gradient(135deg, var(--primary), var(--yellow));
  border-radius: 12px;
  border: 3px solid #100714;
}

.cylinder-panel {
  scrollbar-color: var(--primary) #100714;
  scrollbar-width: thin;
}

.cylinder-panel h2 {
  margin: 0 0 0.9rem;
  color: var(--primary);
  font-size: clamp(1.8rem, 4vw, 3.5rem);
  line-height: 0.95;
  letter-spacing: -0.045em;
}

.cylinder-panel h3 {
  margin: 1.2rem 0 0.35rem;
  color: var(--yellow);
}

.cylinder-panel p,
.cylinder-panel li {
  color: var(--text);
  line-height: 1.62;
}

.cylinder-panel .muted {
  color: var(--muted);
}

.cylinder-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  gap: 0.9rem;
  margin: 1.2rem 0;
}

.cylinder-card {
  padding: 1rem;
  border-radius: 0.9rem;
  background: rgba(0, 0, 0, 0.23);
  border: 1px solid rgba(255, 122, 24, 0.22);
  box-shadow: inset 0 0 28px rgba(0, 250, 206, 0.045);
}

.cylinder-card h3 {
  margin-top: 0;
}

.policy-callout {
  padding: 1rem;
  border-radius: 0.85rem;
  background: linear-gradient(90deg, rgba(255, 122, 24, 0.16), rgba(0, 250, 206, 0.07));
  border: 1px solid rgba(255, 122, 24, 0.32);
}

.code-links {
  display: grid;
  gap: 0.7rem;
  margin: 1rem 0;
}

code {
  display: block;
  overflow-wrap: anywhere;
  white-space: normal;
  background: #050308;
  color: var(--face);
  border: 1px solid rgba(0, 250, 206, 0.28);
  border-radius: 0.55rem;
  padding: 0.65rem;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
  margin-top: 1.1rem;
}

.button {
  display: inline-block;
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 0.75rem 1rem;
  color: var(--text);
  background: rgba(255, 122, 24, 0.12);
  font-weight: 900;
}

.button.primary {
  background: linear-gradient(90deg, var(--primary), var(--yellow));
  color: #170714;
}

.cylinder-controls {
  position: fixed;
  inset: auto 0 32px 0;
  z-index: 70;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0.85rem;
  pointer-events: none;
}

.cylinder-controls > * {
  pointer-events: auto;
}

.cylinder-controls button {
  width: 46px;
  height: 46px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: rgba(6, 3, 8, 0.86);
  color: var(--primary);
  font-size: 1.2rem;
  font-weight: 900;
  cursor: pointer;
}

.cylinder-controls button:hover,
.cylinder-controls button:focus {
  background: var(--primary);
  color: #170714;
}

.cylinder-dots {
  display: flex;
  gap: 0.45rem;
  padding: 0.45rem 0.6rem;
  border: 1px solid rgba(255, 122, 24, 0.25);
  border-radius: 999px;
  background: rgba(6, 3, 8, 0.80);
}

.cylinder-dot {
  width: 12px;
  height: 12px;
  border-radius: 999px;
  border: 1px solid rgba(255, 122, 24, 0.7);
  background: transparent;
  padding: 0;
  cursor: pointer;
}

.cylinder-dot.is-active {
  background: var(--primary);
  box-shadow: 0 0 18px rgba(255, 122, 24, 0.55);
}

.cylinder-footer {
  position: fixed;
  inset: auto 0 0 0;
  z-index: 68;
  padding: 0.55rem 1rem;
  border-top: 1px solid rgba(255, 122, 24, 0.26);
  background: rgba(6, 3, 8, 0.92);
  color: var(--muted);
  font-size: 0.82rem;
  text-align: center;
}

.cylinder-footer a {
  color: var(--primary);
}

body.high-contrast {
  background: #fff !important;
  color: #111 !important;
}

body.high-contrast .cylinder-header,
body.high-contrast .cylinder-panel,
body.high-contrast .cylinder-footer,
body.high-contrast .cylinder-controls button,
body.high-contrast .cylinder-dots {
  background: #fff !important;
  color: #111 !important;
  border-color: #111 !important;
}

body.high-contrast a,
body.high-contrast h1,
body.high-contrast h2,
body.high-contrast .kicker {
  color: #b74600 !important;
}

body.large-text {
  font-size: 1.18em;
}

.display-toggles {
  position: fixed;
  right: 0.8rem;
  top: 92px;
  z-index: 81;
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}

.display-toggles button {
  border: 1px solid var(--line);
  border-radius: 0.65rem;
  background: rgba(6, 3, 8, 0.82);
  color: var(--primary);
  padding: 0.45rem 0.62rem;
  cursor: pointer;
  font-weight: 900;
}

.display-toggles button:hover {
  background: var(--primary);
  color: #170714;
}

@media (prefers-reduced-motion: reduce) {
  .cylinder-track,
  .cylinder-panel {
    transition: none !important;
  }
}

@media (max-width: 820px) {
  .cylinder-header {
    height: auto;
    min-height: 68px;
    align-items: flex-start;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cylinder-header nav {
    justify-content: flex-start;
    font-size: 0.8rem;
  }

  .cylinder-shell {
    padding-top: 132px;
  }

  .display-toggles {
    top: auto;
    right: 0.55rem;
    bottom: 88px;
  }

  .cylinder-stage {
    height: calc(100vh - 286px);
    min-height: 420px;
  }

  .cylinder-ready .cylinder-panel {
    width: 88vw;
    height: min(63vh, 620px);
  }

  .cylinder-page-title h1 {
    font-size: clamp(2rem, 10vw, 3.6rem);
  }

  .cylinder-controls {
    bottom: 34px;
  }

  .cylinder-footer {
    font-size: 0.74rem;
  }
}

@media (max-width: 520px) {
  .cylinder-panel {
    padding: 1rem 0.82rem;
  }

  .cylinder-ready .cylinder-panel {
    width: 92vw;
    height: min(61vh, 600px);
  }

  .cylinder-grid {
    grid-template-columns: 1fr;
  }

  .cylinder-controls button {
    width: 40px;
    height: 40px;
  }

  .cylinder-dot {
    width: 10px;
    height: 10px;
  }
}

/* === 00FACE IMMERSIVE CYLINDER RAILS START === */

/*
  Desktop doctrine:
  - Left rail = identity + nav.
  - Right rail = footer/status.
  - Center stage = horizontal-axis cylinder rolling up/down.
  - Main / diagonal page is untouched because it uses site.css, not cylinder.css.
*/

:root {
  --left-rail: clamp(138px, 10vw, 188px);
  --right-rail: clamp(58px, 5.2vw, 86px);
  --doc-gutter: clamp(0.75rem, 2.2vw, 2.8rem);
  --doc-stage-max: 1680px;
}

body.cylinder-body {
  overflow: auto;
}

body.cylinder-ready {
  overflow: hidden;
}

/* Left immersive rail */
.cylinder-header {
  inset: 0 auto 0 0;
  width: var(--left-rail);
  height: 100vh;
  min-height: 100vh;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  padding: clamp(1rem, 2.4vw, 2rem) 0.8rem;
  border-bottom: 0;
  border-right: 1px solid rgba(255, 122, 24, 0.34);
  background:
    radial-gradient(circle at 50% 10%, rgba(255, 122, 24, 0.24), transparent 12rem),
    linear-gradient(180deg, rgba(6, 3, 8, 0.96), rgba(18, 7, 20, 0.92));
  box-shadow:
    14px 0 44px rgba(0, 0, 0, 0.38),
    inset -1px 0 0 rgba(0, 250, 206, 0.08);
}

.cylinder-brand {
  display: grid;
  place-items: center;
  min-height: 92px;
  margin-bottom: clamp(1rem, 4vh, 2.3rem);
  border: 1px solid rgba(255, 122, 24, 0.38);
  border-radius: 1rem;
  background: rgba(255, 122, 24, 0.08);
  font-size: clamp(1.08rem, 1.5vw, 1.6rem);
  line-height: 1;
  text-align: center;
  text-shadow: 0 0 18px rgba(255, 122, 24, 0.28);
}

.cylinder-header nav {
  display: flex;
  flex-direction: column;
  gap: 0.72rem;
  align-items: stretch;
  justify-content: flex-start;
  font-size: clamp(0.82rem, 0.85vw, 0.98rem);
}

.cylinder-header nav a {
  display: block;
  text-align: center;
  padding: 0.74rem 0.52rem;
  border-color: rgba(255, 122, 24, 0.28);
  background:
    linear-gradient(90deg, rgba(255, 122, 24, 0.11), rgba(0, 250, 206, 0.035));
  box-shadow: inset 0 0 20px rgba(255, 122, 24, 0.035);
}

/* Right immersive status/footer rail */
.cylinder-footer {
  inset: 0 0 0 auto;
  width: var(--right-rail);
  height: 100vh;
  padding: 1rem 0.45rem;
  border-top: 0;
  border-left: 1px solid rgba(255, 122, 24, 0.30);
  background:
    radial-gradient(circle at 50% 88%, rgba(0, 250, 206, 0.13), transparent 10rem),
    linear-gradient(180deg, rgba(18, 7, 20, 0.92), rgba(6, 3, 8, 0.96));
  box-shadow:
    -14px 0 44px rgba(0, 0, 0, 0.34),
    inset 1px 0 0 rgba(255, 122, 24, 0.07);
  writing-mode: vertical-rl;
  text-orientation: mixed;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.cylinder-footer a {
  color: var(--face);
}

/* Center document cockpit */
.cylinder-shell {
  min-height: 100vh;
  padding:
    clamp(1rem, 2.4vw, 2rem)
    calc(var(--right-rail) + var(--doc-gutter))
    clamp(1rem, 2.4vw, 2rem)
    calc(var(--left-rail) + var(--doc-gutter));
}

.cylinder-page-title {
  width: min(var(--doc-stage-max), 100%);
  margin: 0 auto 0.8rem;
  padding: 0 clamp(0.4rem, 1vw, 1rem);
}

.cylinder-page-title h1 {
  font-size: clamp(2.4rem, 5.2vw, 6.8rem);
}

.cylinder-stage {
  width: min(var(--doc-stage-max), 100%);
  margin: 0 auto;
  height: calc(100vh - clamp(190px, 21vh, 270px));
  min-height: 520px;
  border-radius: 1.4rem;
  overflow: hidden;
}

/* Subtle top/bottom curvature glows */
.cylinder-stage::before,
.cylinder-stage::after {
  content: "";
  position: absolute;
  left: 50%;
  width: min(940px, 76%);
  height: 120px;
  transform: translateX(-50%);
  pointer-events: none;
  z-index: 30;
  border-radius: 999px;
  filter: blur(22px);
  opacity: 0.34;
}

.cylinder-stage::before {
  top: -76px;
  background: radial-gradient(ellipse, rgba(255, 122, 24, 0.34), transparent 70%);
}

.cylinder-stage::after {
  bottom: -76px;
  background: radial-gradient(ellipse, rgba(0, 250, 206, 0.20), transparent 70%);
}

.cylinder-ready .cylinder-panel {
  width: min(900px, 82%);
  height: min(68vh, 720px);
}

.cylinder-controls {
  inset:
    auto
    calc(var(--right-rail) + var(--doc-gutter))
    clamp(1.1rem, 3vh, 2rem)
    calc(var(--left-rail) + var(--doc-gutter));
}

.display-toggles {
  right: calc(var(--right-rail) + 0.7rem);
  top: clamp(1rem, 2.4vw, 2rem);
}

/* Jumbo / ultrawide refinements */
@media (min-width: 1600px) {
  :root {
    --left-rail: clamp(176px, 10vw, 220px);
    --right-rail: clamp(72px, 4.8vw, 104px);
    --doc-stage-max: 1860px;
  }

  .cylinder-stage {
    height: calc(100vh - 250px);
    min-height: 660px;
    perspective: 2200px;
  }

  .cylinder-ready .cylinder-panel {
    width: min(1040px, 72%);
    height: min(70vh, 850px);
  }

  .cylinder-panel {
    font-size: 1.06rem;
  }
}

@media (min-width: 2200px) {
  :root {
    --left-rail: 250px;
    --right-rail: 124px;
    --doc-stage-max: 2300px;
  }

  .cylinder-stage {
    height: calc(100vh - 290px);
    min-height: 760px;
    perspective: 2700px;
  }

  .cylinder-ready .cylinder-panel {
    width: min(1220px, 68%);
    height: min(72vh, 980px);
  }

  .cylinder-panel {
    font-size: 1.15rem;
  }
}

/* Laptop/tablet: rails become immersive top/bottom bars */
@media (max-width: 1099px) {
  :root {
    --left-rail: 0px;
    --right-rail: 0px;
    --doc-gutter: clamp(0.7rem, 3vw, 1.5rem);
  }

  body.cylinder-ready {
    overflow: hidden;
  }

  .cylinder-header {
    inset: 0 0 auto 0;
    width: 100%;
    height: auto;
    min-height: 76px;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem clamp(0.75rem, 3vw, 1.35rem);
    border-right: 0;
    border-bottom: 1px solid rgba(255, 122, 24, 0.34);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.34);
  }

  .cylinder-brand {
    min-height: 0;
    margin: 0;
    padding: 0.65rem 0.75rem;
    font-size: 1rem;
    white-space: nowrap;
  }

  .cylinder-header nav {
    flex-direction: row;
    gap: 0.45rem;
    overflow-x: auto;
    max-width: calc(100vw - 138px);
    padding-bottom: 0.1rem;
  }

  .cylinder-header nav a {
    flex: 0 0 auto;
    padding: 0.52rem 0.68rem;
    white-space: nowrap;
  }

  .cylinder-shell {
    padding: 96px var(--doc-gutter) 76px;
  }

  .cylinder-page-title {
    margin-bottom: 0.45rem;
  }

  .cylinder-stage {
    width: 100%;
    height: calc(100vh - 260px);
    min-height: 430px;
    perspective: 1550px;
  }

  .cylinder-ready .cylinder-panel {
    width: min(860px, 88vw);
    height: min(62vh, 640px);
  }

  .cylinder-footer {
    inset: auto 0 0 0;
    width: 100%;
    height: auto;
    min-height: 42px;
    padding: 0.55rem 1rem;
    border-left: 0;
    border-top: 1px solid rgba(255, 122, 24, 0.30);
    writing-mode: horizontal-tb;
    text-orientation: mixed;
    letter-spacing: 0.03em;
    text-transform: none;
    flex-direction: row;
  }

  .cylinder-controls {
    inset: auto 0 44px 0;
  }

  .display-toggles {
    right: 0.65rem;
    top: auto;
    bottom: 88px;
  }
}

/* Phone and small tablets */
@media (max-width: 720px) {
  .cylinder-header {
    align-items: stretch;
    flex-direction: column;
    gap: 0.55rem;
    min-height: 116px;
  }

  .cylinder-brand {
    width: fit-content;
  }

  .cylinder-header nav {
    max-width: 100%;
    font-size: 0.78rem;
  }

  .cylinder-header nav a {
    padding: 0.46rem 0.58rem;
  }

  .cylinder-shell {
    padding: 132px 0.6rem 78px;
  }

  .cylinder-page-title h1 {
    font-size: clamp(2rem, 12vw, 3.9rem);
  }

  .cylinder-page-title p {
    font-size: 0.92rem;
  }

  .cylinder-stage {
    height: calc(100vh - 310px);
    min-height: 390px;
    border-radius: 1rem;
    perspective: 1250px;
  }

  .cylinder-ready .cylinder-panel {
    width: 92vw;
    height: min(58vh, 590px);
    padding: 1rem 0.9rem;
  }

  .cylinder-panel h2 {
    font-size: clamp(1.72rem, 10vw, 2.75rem);
  }

  .cylinder-controls {
    bottom: 42px;
    gap: 0.55rem;
  }

  .cylinder-controls button {
    width: 40px;
    height: 40px;
  }

  .cylinder-dots {
    max-width: 54vw;
    overflow-x: auto;
  }

  .display-toggles {
    right: 0.45rem;
    bottom: 86px;
  }

  .display-toggles button {
    padding: 0.38rem 0.52rem;
  }

  .cylinder-footer {
    font-size: 0.72rem;
    line-height: 1.25;
  }
}

/* Very small phones */
@media (max-width: 420px) {
  .cylinder-shell {
    padding-left: 0.35rem;
    padding-right: 0.35rem;
  }

  .cylinder-stage {
    height: calc(100vh - 318px);
    min-height: 360px;
  }

  .cylinder-ready .cylinder-panel {
    width: 94vw;
    height: min(56vh, 560px);
    padding: 0.85rem 0.72rem;
  }

  .cylinder-grid {
    gap: 0.65rem;
  }

  .cylinder-card {
    padding: 0.78rem;
  }
}

/* Landscape phones: keep controls usable */
@media (max-height: 560px) and (orientation: landscape) {
  .cylinder-header {
    min-height: 64px;
    flex-direction: row;
  }

  .cylinder-shell {
    padding-top: 76px;
    padding-bottom: 52px;
  }

  .cylinder-page-title {
    display: none;
  }

  .cylinder-stage {
    height: calc(100vh - 128px);
    min-height: 300px;
  }

  .cylinder-ready .cylinder-panel {
    height: min(72vh, 420px);
  }

  .cylinder-controls {
    bottom: 30px;
  }

  .display-toggles {
    bottom: 62px;
  }
}

/* === 00FACE IMMERSIVE CYLINDER RAILS END === */

/* No-JS / failed-JS readability fallback */
body.cylinder-body:not(.cylinder-ready) .cylinder-header {
  position: sticky;
  top: 0;
}

body.cylinder-body:not(.cylinder-ready) .cylinder-footer {
  position: static;
  width: auto;
  height: auto;
  writing-mode: horizontal-tb;
}

body.cylinder-body:not(.cylinder-ready) .cylinder-stage {
  width: min(980px, 94vw);
  height: auto;
  min-height: 0;
  margin: 0 auto;
  overflow: visible;
}

body.cylinder-body:not(.cylinder-ready) .cylinder-track {
  transform: none !important;
}

body.cylinder-body:not(.cylinder-ready) .cylinder-panel {
  position: static;
  transform: none !important;
  opacity: 1;
  pointer-events: auto;
  height: auto;
  max-height: none;
  overflow: visible;
}
