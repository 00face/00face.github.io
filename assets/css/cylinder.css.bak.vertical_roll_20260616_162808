:root {
  --bg: #060308;
  --bg2: #120714;
  --panel: #1a0b20;
  --panel2: #281033;
  --primary: #ff7a18;
  --primary2: #ff9f1c;
  --face: #00face;
  --purple: #7a35ff;
  --yellow: #ffd447;
  --text: #fff8ef;
  --muted: #d8c6b5;
  --line: rgba(255, 122, 24, 0.45);
  --shadow: rgba(0, 0, 0, 0.62);
}

* {
  box-sizing: border-box;
}

html {
  background: var(--bg);
  color: var(--text);
}

body.cylinder-body {
  min-height: 100vh;
  margin: 0;
  overflow: auto;
  color: var(--text);
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
  background:
    radial-gradient(circle at 12% 10%, rgba(255, 122, 24, 0.30), transparent 28rem),
    radial-gradient(circle at 88% 12%, rgba(0, 250, 206, 0.17), transparent 24rem),
    radial-gradient(circle at 70% 90%, rgba(122, 53, 255, 0.22), transparent 28rem),
    linear-gradient(135deg, #060308 0%, #120714 56%, #1f0b10 100%);
}

body.cylinder-ready {
  overflow: hidden;
}

a {
  color: var(--face);
  text-decoration: none;
}

a:hover,
a:focus {
  color: var(--yellow);
  text-decoration: underline;
}

.cylinder-header {
  position: fixed;
  inset: 0 0 auto 0;
  z-index: 80;
  height: 72px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.8rem clamp(1rem, 4vw, 3rem);
  background: rgba(6, 3, 8, 0.86);
  border-bottom: 1px solid rgba(255, 122, 24, 0.32);
  backdrop-filter: blur(16px);
}

.cylinder-brand {
  font-weight: 1000;
  letter-spacing: 0.08em;
  color: var(--primary);
  text-transform: uppercase;
}

.cylinder-brand span {
  color: var(--face);
}

.cylinder-header nav {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
  justify-content: flex-end;
  font-size: 0.92rem;
}

.cylinder-header nav a {
  color: var(--text);
  border: 1px solid rgba(255, 122, 24, 0.25);
  border-radius: 999px;
  padding: 0.42rem 0.72rem;
  background: rgba(255, 122, 24, 0.08);
}

.cylinder-header nav a:hover,
.cylinder-header nav a:focus {
  color: #180812;
  background: var(--primary);
  text-decoration: none;
}

.cylinder-shell {
  min-height: 100vh;
  padding-top: 82px;
  padding-bottom: 76px;
}

.cylinder-page-title {
  position: relative;
  z-index: 10;
  width: min(1040px, 92vw);
  margin: 0 auto 0.4rem;
  text-align: center;
}

.cylinder-page-title .kicker {
  margin: 0;
}

.kicker {
  color: var(--face);
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 0.82rem;
  font-weight: 900;
}

.cylinder-page-title h1 {
  margin: 0.15rem 0 0.2rem;
  color: var(--primary);
  font-size: clamp(2.2rem, 6vw, 5.4rem);
  line-height: 0.9;
  letter-spacing: -0.06em;
  text-shadow: 0 0 28px rgba(255, 122, 24, 0.25);
}

.cylinder-page-title p {
  margin: 0.35rem auto;
  max-width: 780px;
  color: var(--muted);
}

.cylinder-stage {
  position: relative;
  width: 100vw;
  height: calc(100vh - 236px);
  min-height: 470px;
  overflow: hidden;
  perspective: 1800px;
  perspective-origin: 50% 50%;
}

.cylinder-track {
  position: relative;
  width: 100%;
  height: 100%;
  transform-style: preserve-3d;
  transition: transform 720ms cubic-bezier(0.22, 1.04, 0.56, 1.05);
}

.cylinder-panel {
  width: min(860px, 86vw);
  margin: 1.2rem auto;
  padding: clamp(1.15rem, 3vw, 2.2rem);
  border-radius: 1.25rem;
  background:
    linear-gradient(135deg, rgba(54, 20, 29, 0.97), rgba(22, 8, 28, 0.97)),
    radial-gradient(circle at 78% 20%, rgba(0, 250, 206, 0.12), transparent 16rem);
  border: 1px solid var(--line);
  box-shadow:
    0 22px 70px var(--shadow),
    inset 0 0 42px rgba(255, 122, 24, 0.08);
}

.cylinder-ready .cylinder-panel {
  position: absolute;
  top: 50%;
  left: 50%;
  height: min(68vh, 720px);
  max-height: 720px;
  margin: 0;
  opacity: 0.18;
  pointer-events: none;
  overflow: hidden;
  transform-style: preserve-3d;
  backface-visibility: hidden;
  transition:
    opacity 520ms ease,
    filter 520ms ease,
    box-shadow 520ms ease;
  filter: blur(0.8px) saturate(0.72);
}

.cylinder-ready .cylinder-panel.is-active {
  opacity: 1;
  pointer-events: auto;
  overflow-y: auto;
  filter: none;
  z-index: 20;
  box-shadow:
    0 24px 90px rgba(0, 0, 0, 0.74),
    0 0 44px rgba(255, 122, 24, 0.16),
    inset 0 0 44px rgba(0, 250, 206, 0.05);
}

.cylinder-panel::-webkit-scrollbar {
  width: 14px;
  background: #100714;
  border-radius: 12px;
}

.cylinder-panel::-webkit-scrollbar-thumb {
  background: linear-gradient(135deg, var(--primary), var(--yellow));
  border-radius: 12px;
  border: 3px solid #100714;
}

.cylinder-panel {
  scrollbar-color: var(--primary) #100714;
  scrollbar-width: thin;
}

.cylinder-panel h2 {
  margin: 0 0 0.9rem;
  color: var(--primary);
  font-size: clamp(1.8rem, 4vw, 3.5rem);
  line-height: 0.95;
  letter-spacing: -0.045em;
}

.cylinder-panel h3 {
  margin: 1.2rem 0 0.35rem;
  color: var(--yellow);
}

.cylinder-panel p,
.cylinder-panel li {
  color: var(--text);
  line-height: 1.62;
}

.cylinder-panel .muted {
  color: var(--muted);
}

.cylinder-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  gap: 0.9rem;
  margin: 1.2rem 0;
}

.cylinder-card {
  padding: 1rem;
  border-radius: 0.9rem;
  background: rgba(0, 0, 0, 0.23);
  border: 1px solid rgba(255, 122, 24, 0.22);
  box-shadow: inset 0 0 28px rgba(0, 250, 206, 0.045);
}

.cylinder-card h3 {
  margin-top: 0;
}

.policy-callout {
  padding: 1rem;
  border-radius: 0.85rem;
  background: linear-gradient(90deg, rgba(255, 122, 24, 0.16), rgba(0, 250, 206, 0.07));
  border: 1px solid rgba(255, 122, 24, 0.32);
}

.code-links {
  display: grid;
  gap: 0.7rem;
  margin: 1rem 0;
}

code {
  display: block;
  overflow-wrap: anywhere;
  white-space: normal;
  background: #050308;
  color: var(--face);
  border: 1px solid rgba(0, 250, 206, 0.28);
  border-radius: 0.55rem;
  padding: 0.65rem;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
  margin-top: 1.1rem;
}

.button {
  display: inline-block;
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 0.75rem 1rem;
  color: var(--text);
  background: rgba(255, 122, 24, 0.12);
  font-weight: 900;
}

.button.primary {
  background: linear-gradient(90deg, var(--primary), var(--yellow));
  color: #170714;
}

.cylinder-controls {
  position: fixed;
  inset: auto 0 32px 0;
  z-index: 70;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0.85rem;
  pointer-events: none;
}

.cylinder-controls > * {
  pointer-events: auto;
}

.cylinder-controls button {
  width: 46px;
  height: 46px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: rgba(6, 3, 8, 0.86);
  color: var(--primary);
  font-size: 1.2rem;
  font-weight: 900;
  cursor: pointer;
}

.cylinder-controls button:hover,
.cylinder-controls button:focus {
  background: var(--primary);
  color: #170714;
}

.cylinder-dots {
  display: flex;
  gap: 0.45rem;
  padding: 0.45rem 0.6rem;
  border: 1px solid rgba(255, 122, 24, 0.25);
  border-radius: 999px;
  background: rgba(6, 3, 8, 0.80);
}

.cylinder-dot {
  width: 12px;
  height: 12px;
  border-radius: 999px;
  border: 1px solid rgba(255, 122, 24, 0.7);
  background: transparent;
  padding: 0;
  cursor: pointer;
}

.cylinder-dot.is-active {
  background: var(--primary);
  box-shadow: 0 0 18px rgba(255, 122, 24, 0.55);
}

.cylinder-footer {
  position: fixed;
  inset: auto 0 0 0;
  z-index: 68;
  padding: 0.55rem 1rem;
  border-top: 1px solid rgba(255, 122, 24, 0.26);
  background: rgba(6, 3, 8, 0.92);
  color: var(--muted);
  font-size: 0.82rem;
  text-align: center;
}

.cylinder-footer a {
  color: var(--primary);
}

body.high-contrast {
  background: #fff !important;
  color: #111 !important;
}

body.high-contrast .cylinder-header,
body.high-contrast .cylinder-panel,
body.high-contrast .cylinder-footer,
body.high-contrast .cylinder-controls button,
body.high-contrast .cylinder-dots {
  background: #fff !important;
  color: #111 !important;
  border-color: #111 !important;
}

body.high-contrast a,
body.high-contrast h1,
body.high-contrast h2,
body.high-contrast .kicker {
  color: #b74600 !important;
}

body.large-text {
  font-size: 1.18em;
}

.display-toggles {
  position: fixed;
  right: 0.8rem;
  top: 92px;
  z-index: 81;
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}

.display-toggles button {
  border: 1px solid var(--line);
  border-radius: 0.65rem;
  background: rgba(6, 3, 8, 0.82);
  color: var(--primary);
  padding: 0.45rem 0.62rem;
  cursor: pointer;
  font-weight: 900;
}

.display-toggles button:hover {
  background: var(--primary);
  color: #170714;
}

@media (prefers-reduced-motion: reduce) {
  .cylinder-track,
  .cylinder-panel {
    transition: none !important;
  }
}

@media (max-width: 820px) {
  .cylinder-header {
    height: auto;
    min-height: 68px;
    align-items: flex-start;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cylinder-header nav {
    justify-content: flex-start;
    font-size: 0.8rem;
  }

  .cylinder-shell {
    padding-top: 132px;
  }

  .display-toggles {
    top: auto;
    right: 0.55rem;
    bottom: 88px;
  }

  .cylinder-stage {
    height: calc(100vh - 286px);
    min-height: 420px;
  }

  .cylinder-ready .cylinder-panel {
    width: 88vw;
    height: min(63vh, 620px);
  }

  .cylinder-page-title h1 {
    font-size: clamp(2rem, 10vw, 3.6rem);
  }

  .cylinder-controls {
    bottom: 34px;
  }

  .cylinder-footer {
    font-size: 0.74rem;
  }
}

@media (max-width: 520px) {
  .cylinder-panel {
    padding: 1rem 0.82rem;
  }

  .cylinder-ready .cylinder-panel {
    width: 92vw;
    height: min(61vh, 600px);
  }

  .cylinder-grid {
    grid-template-columns: 1fr;
  }

  .cylinder-controls button {
    width: 40px;
    height: 40px;
  }

  .cylinder-dot {
    width: 10px;
    height: 10px;
  }
}
